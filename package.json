{
  "name": "opengravity",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent-first AI development, local and free. A standalone alternative to Google Antigravity.",
  "main": "dist/app/main.js",
  "homepage": "https://github.com/johnvteixido/OpenGravity",
  "author": {
    "name": "John V. Teixido",
    "email": "johnvteixido@users.noreply.github.com",
    "url": "https://github.com/johnvteixido"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnvteixido/OpenGravity.git"
  },
  "bugs": {
    "url": "https://github.com/johnvteixido/OpenGravity/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-assistant",
    "ollama",
    "local-ai",
    "open-source",
    "electron",
    "developer-tools"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:python\" \"wait-on http://localhost:7432/health && npm run dev:electron\"",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev:renderer": "vite --config vite.config.mjs",
    "dev:python": "python -m uvicorn core.server.api:app --host 127.0.0.1 --port 7432 --reload",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build --config vite.config.mjs",
    "build:electron": "tsc -p tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "lint": "eslint . --ext .ts,.tsx && prettier --check .",
    "lint:fix": "eslint . --ext .ts,.tsx --fix && prettier --write .",
    "test": "cd core && python -m pytest tests/ -v",
    "test:renderer": "vitest run",
    "test:python": "cd core && python -m pytest tests/ -v",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "lucide-react": "^1.7.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "dev.opengravity.app",
    "productName": "OpenGravity",
    "copyright": "Copyright © 2026 John V. Teixido",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "core/**/*",
      "scripts/**/*",
      "!core/**/__pycache__",
      "!core/**/*.pyc"
    ],
    "extraResources": [
      {
        "from": "core/",
        "to": "core/",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!**/*.pyc"
        ]
      },
      {
        "from": "scripts/",
        "to": "scripts/"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
